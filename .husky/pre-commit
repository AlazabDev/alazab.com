#!/bin/bash

# Pre-commit hook to run linting and formatting checks

echo "Running pre-commit checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx)$')

if [ -z "$STAGED_FILES" ]; then
  echo -e "${GREEN}✓ No TypeScript/JavaScript files to check${NC}"
  exit 0
fi

echo "Checking files:"
echo "$STAGED_FILES"

# Run ESLint
echo -e "\n${YELLOW}Running ESLint...${NC}"
pnpm exec eslint $STAGED_FILES --fix

if [ $? -ne 0 ]; then
  echo -e "${RED}✗ ESLint check failed${NC}"
  exit 1
fi

# Run TypeScript check
echo -e "\n${YELLOW}Running TypeScript check...${NC}"
pnpm exec tsc --noEmit

if [ $? -ne 0 ]; then
  echo -e "${RED}✗ TypeScript check failed${NC}"
  exit 1
fi

# Add fixed files back to staging
git add $STAGED_FILES

echo -e "\n${GREEN}✓ Pre-commit checks passed${NC}"
exit 0
